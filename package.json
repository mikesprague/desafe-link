{
  "name": "desafe-link",
  "version": "1.0.0-rc.2",
  "description": "Microsoft Safe Link Unfurler",
  "private": true,
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "type": "module",
  "scripts": {
    "build": "npx tsc -b && npx vite build",
    "clean": "rm -rf ./build",
    "dev": "npx vite serve",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint src",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "start": "npm run dev",
    "test": "npm run format:check && npm run lint && npm run typecheck",
    "typecheck": "npx tsc --noEmit"
  },
  "repository": {
    "url": "https://github.com/mikesprague/desafe-link"
  },
  "keywords": [],
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/desafe-link/issues"
  },
  "homepage": "https://mikesprague.github.io/desafe-link",
  "dependencies": {
    "@fontsource-variable/geist": "5.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "emoji-blast": "0.11.0",
    "jotai": "2.20.2",
    "lucide-react": "1.26.0",
    "radix-ui": "1.6.5",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.82.0",
    "react-icons": "5.7.0",
    "shadcn": "4.14.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "globals": "17.7.0",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.5"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.0",
    "npm": "11.17.0"
  }
}
